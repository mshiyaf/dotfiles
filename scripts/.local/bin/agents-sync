#!/usr/bin/env bun

import fs from "node:fs";
import path from "node:path";

type ModelMap = Record<string, { opencode: string; claude: string; codex: string }>;

const EDIT_CAPABLE = new Set(["debugger", "tester", "docs-writer", "pr-writer"]);
const EDIT_DENY = new Set([
  "reviewer",
  "security-reviewer",
  "critic",
  "architect",
  "refactor-planner",
  "researcher",
]);
const CLAUDE_READ_ONLY_TOOLS = "Read, Grep, Glob, Bash";
const CLAUDE_EDIT_TOOLS = "Read, Grep, Glob, Bash, Edit, Write";

const repo = findRepoRoot(process.cwd());
const check = process.argv.includes("--check");

function findRepoRoot(start: string): string {
  let dir = start;
  while (true) {
    if (fs.existsSync(path.join(dir, "agents")) && fs.existsSync(path.join(dir, "opencode"))) return dir;
    const parent = path.dirname(dir);
    if (parent === dir) throw new Error("Could not find dotfiles repo root");
    dir = parent;
  }
}

function parseAgent(file: string): { description: string; body: string } {
  const raw = fs.readFileSync(file, "utf8");
  const match = raw.match(/^---\n([\s\S]*?)\n---\n?([\s\S]*)$/);
  if (!match) throw new Error(`Missing frontmatter: ${file}`);
  const description = match[1].match(/^description:\s*(.*)$/m)?.[1]?.trim();
  if (!description) throw new Error(`Missing description: ${file}`);
  return { description, body: match[2].trimEnd() + "\n" };
}

function yamlQuote(value: string): string {
  return JSON.stringify(value);
}

function tomlString(value: string): string {
  return JSON.stringify(value);
}

function tomlMultiline(value: string): string {
  return `'''\n${value.replace(/'''/g, "''\\''")}'''`;
}

function ensureDir(dir: string) {
  fs.mkdirSync(dir, { recursive: true });
}

function writeOrCheck(file: string, content: string): boolean {
  if (check) {
    const current = fs.existsSync(file) ? fs.readFileSync(file, "utf8") : "";
    if (current !== content) {
      console.error(`stale: ${path.relative(repo, file)}`);
      return false;
    }
    return true;
  }
  fs.writeFileSync(file, content);
  return true;
}

const modelsPath = path.join(repo, "agents", "models.json");
const models = JSON.parse(fs.readFileSync(modelsPath, "utf8")) as ModelMap;
const sourceDir = path.join(repo, "opencode", ".config", "opencode", "agents");
const claudeDir = path.join(repo, "agents", ".claude", "agents");
const codexDir = path.join(repo, "agents", ".codex", "agents");

ensureDir(claudeDir);
ensureDir(codexDir);

let ok = true;
for (const role of Object.keys(models).sort()) {
  const source = path.join(sourceDir, `${role}.md`);
  if (!fs.existsSync(source)) throw new Error(`Missing source agent: ${source}`);
  const { description, body } = parseAgent(source);
  const generated = `# GENERATED by agents-sync - edit opencode/.config/opencode/agents/${role}.md instead`;
  const readOnly = EDIT_DENY.has(role);
  if (!readOnly && !EDIT_CAPABLE.has(role)) throw new Error(`Role is neither edit-deny nor edit-capable: ${role}`);

  const claudeBody = readOnly ? `${body}\nRead-only role: do not edit files.\n` : body;
  const claude = `${generated}\n---\nname: ${role}\ndescription: ${yamlQuote(description)}\nmodel: ${models[role].claude}\ntools: ${readOnly ? CLAUDE_READ_ONLY_TOOLS : CLAUDE_EDIT_TOOLS}\n---\n${claudeBody}`;
  ok = writeOrCheck(path.join(claudeDir, `${role}.md`), claude) && ok;

  const codex = `${generated}\nname = ${tomlString(role)}\ndescription = ${tomlString(description)}\ndeveloper_instructions = ${tomlMultiline(body)}\nmodel = ${tomlString(models[role].codex)}\nsandbox_mode = ${tomlString(readOnly ? "read-only" : "workspace-write")}\n`;
  ok = writeOrCheck(path.join(codexDir, `${role}.toml`), codex) && ok;
}

process.exit(ok ? 0 : 1);
