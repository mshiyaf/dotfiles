# explicit reload of zprofile
alias reload-secrets='source ~/.zprofile'
alias encs='encrypt_secrets'
alias load-secrets='load_secrets'

# android emulator - for fix related to qt
alias emulator='QT_QPA_PLATFORM=xcb DISPLAY=:1 emulator'
alias pixel='emulator -avd Pixel_10 &>/dev/null &'

# Mount/unmount Windows backup VHD
function mount-backup() {
    sudo modprobe nbd max_part=8
    sudo qemu-nbd --connect=/dev/nbd0 /home/mshiyaf/windows-backup/wsl-backup.vhdx
    sudo mkdir -p /mnt/backup
    sudo mount /dev/nbd0 /mnt/backup
    cd /mnt/backup
}

function umount-backup() {
    cd ~
    sudo umount /mnt/backup
    sudo qemu-nbd --disconnect /dev/nbd0
    sudo rmmod nbd
}
