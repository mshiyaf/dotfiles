# Help people new to Arch
alias apt="man pacman"
alias apt-get="man pacman"
alias please="sudo"
alias tb="nc termbin.com 9999"

# Cleanup orphaned packages
alias cleanup='sudo pacman -Rsn $(pacman -Qtdq)'

# Get the error messages from journalctl
alias jctl="journalctl -p 3 -xb"

# Recent installed packages
alias rip="expac --timefmt='%Y-%m-%d %T' '%l\t%n %v' | sort | tail -200 | nl"

alias ls="eza -g -G --icons"
alias la="ls -a"
alias g=git
alias python=python3
# alias vi=vim
alias t=tmux
alias ta="tmux a"
# alias backup="python ~/OneDrive/Back\ Up/backup_script.py"
alias fin=fzf
alias yt=youtube-dl
alias top=btop
alias ll="eza -l -g --icons"
alias lla="ll -a"

alias bladeformatter="blade-formatter"

alias lg="lazygit"

# yazi: cd into directory on quit
function y() {
    local tmp="$(mktemp -t "yazi-cwd.XXXXXX")" cwd
    yazi "$@" --cwd-file="$tmp"
    if cwd="$(command cat -- "$tmp")" && [ -n "$cwd" ] && [ "$cwd" != "$PWD" ]; then
        builtin cd -- "$cwd"
    fi
    rm -f -- "$tmp"
}

alias ssh='TERM=xterm-256color ssh'
if [[ "$(uname)" == "Linux" ]]; then
  if grep -qi microsoft /proc/version; then
    # This is WSL
    alias open='explorer.exe'
  else
    # This is native Linux
    function open() { nautilus "${@:-.}" &>/dev/null & disown; }
  fi
fi

alias pn=pnpm

# Ollama (local LLM)
alias ai-start="sudo systemctl start ollama.service"
alias ai-stop="sudo systemctl stop ollama.service"
alias ai-status="systemctl status ollama.service"

alias ide="source ~/dev/github.com/mshiyaf/dotfiles/zsh/.config/zsh/ide_session.sh"


