#compdef git-wt

# Completion for the `git-wt` script (invoked as `git-wt ...`; the `git wt`
# subcommand form is completed by git's own dispatcher via this file's #compdef).

# Branches that currently have a worktree (for path/rm).
__gitwt_worktree_branches() {
    local -a branches
    branches=(${(f)"$(git worktree list --porcelain 2>/dev/null \
        | awk '/^branch /{sub("refs/heads/","",$2); print $2}')"})
    _describe -t worktrees 'worktree branch' branches
}

# All local branches (for -b / start-point).
__gitwt_all_branches() {
    local -a branches
    branches=(${(f)"$(git for-each-ref --format='%(refname:short)' refs/heads 2>/dev/null)"})
    _describe -t branches 'branch' branches
}

_git-wt() {
    local curcontext="$curcontext" state line
    local -a subcommands
    subcommands=(
        'new:create a worktree for a branch'
        'add:alias for new'
        'list:list worktrees for this repo'
        'ls:alias for list'
        'path:print a worktree path'
        'rm:remove a worktree'
        'remove:alias for rm'
        'prune:prune stale worktree metadata'
        'help:show help'
    )

    _arguments -C '1: :->cmd' '*:: :->args' && return 0

    case $state in
        cmd)
            _describe -t commands 'git wt command' subcommands
            ;;
        args)
            case $line[1] in
                new|add)
                    _arguments \
                        '(-b --branch)'{-b,--branch}'[branch name]:branch:__gitwt_all_branches' \
                        '--no-setup[skip the post-create hook]' \
                        '*:start-point:__gitwt_all_branches'
                    ;;
                path)
                    __gitwt_worktree_branches
                    ;;
                rm|remove)
                    _arguments \
                        '-D[also delete the branch]' \
                        '(--force -f)'{--force,-f}'[discard uncommitted work]' \
                        '*:branch:__gitwt_worktree_branches'
                    ;;
            esac
            ;;
    esac
}

_git-wt "$@"
