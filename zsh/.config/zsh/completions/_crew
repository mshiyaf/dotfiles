#compdef crew

# Completion for the `crew` tmux/herdr multi-agent orchestrator.

# Known crewmates from crew's own state dirs (works for both the tmux and herdr
# backends, even when neither server is reachable). The branch files hold the
# un-sanitized branch names attach/stop expect.
__crew_sessions() {
    local -a mates
    local sd="${XDG_STATE_HOME:-$HOME/.local/state}/crew"
    mates=(${(f)"$(cat "$sd"/*/*/branch(N.) 2>/dev/null | sort -u)"})
    _describe -t sessions 'crewmate branch' mates
}

__crew_all_branches() {
    local -a branches
    branches=(${(f)"$(git for-each-ref --format='%(refname:short)' refs/heads 2>/dev/null)"})
    _describe -t branches 'branch' branches
}

_crew() {
    local curcontext="$curcontext" state line
    local -a subcommands
    subcommands=(
        'new:create a worktree + session/workspace running an agent (branch AI-named from the task)'
        'ls:list active crew sessions'
        'list:list active crew sessions'
        'attach:attach/switch to a crewmate session'
        'stop:kill a session (-D also removes worktree + branch)'
        'rm:kill a session (-D also removes worktree + branch)'
        'help:show help'
    )

    _arguments -C '1: :->cmd' '*:: :->args' && return 0

    case $state in
        cmd)
            _describe -t commands 'crew command' subcommands
            ;;
        args)
            case $line[1] in
                new)
                    _arguments \
                        '(-b --branch)'{-b,--branch}'[reuse/force a branch instead of AI-naming]:branch:__crew_all_branches' \
                        '--start[branch start-point]:ref:__crew_all_branches' \
                        '--attach[jump into the session now]' \
                        '--claude[use the claude engine]' \
                        '--codex[use the codex engine]' \
                        '--kimi[use the Kimi Code engine]' \
                        '--amp[use the Amp engine]' \
                        '--headless[bounded non-interactive run (herdr; default on tmux)]' \
                        '--profile[model profile]:profile:(fast standard deep)'
                    ;;
                attach)
                    __crew_sessions
                    ;;
                stop|rm)
                    _arguments \
                        '-D[also remove worktree + branch]' \
                        '*:session:__crew_sessions'
                    ;;
            esac
            ;;
    esac
}

_crew "$@"
