#compdef wt

# Completion for the `wt` zsh function (see .aliasrc). First word can be a
# git-wt subcommand, `-b`, an existing worktree to cd into, or a free-text task.

__wt_worktree_branches() {
    local -a branches
    branches=(${(f)"$(git worktree list --porcelain 2>/dev/null \
        | awk '/^branch /{sub("refs/heads/","",$2); print $2}')"})
    _describe -t worktrees 'worktree branch' branches
}

__wt_all_branches() {
    local -a branches
    branches=(${(f)"$(git for-each-ref --format='%(refname:short)' refs/heads 2>/dev/null)"})
    _describe -t branches 'branch' branches
}

_wt() {
    if (( CURRENT == 2 )); then
        local -a firstargs
        firstargs=(
            'list:list worktrees' 'ls:list worktrees'
            'rm:remove a worktree' 'remove:remove a worktree'
            'prune:prune stale metadata' 'path:print a worktree path'
            'new:create a worktree' 'add:create a worktree'
            'help:show help'
            '-b:explicit branch name' '--branch:explicit branch name'
        )
        _describe -t commands 'wt command' firstargs
        __wt_worktree_branches
        return
    fi

    case ${words[2]} in
        rm|remove|path) __wt_worktree_branches ;;
        new|add)        __wt_all_branches ;;
        -b|--branch)    (( CURRENT == 3 )) && __wt_all_branches ;;
    esac
}

_wt "$@"
