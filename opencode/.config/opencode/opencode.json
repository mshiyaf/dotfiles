{
  "$schema": "https://opencode.ai/config.json",
  "model": "kimi-for-coding/k2p6",
  "default_agent": "build",
  "plugin": ["oc-codex-multi-auth"],
  "permission": {
    "skill": {
      "*": "ask",
      "laravel-*": "deny",
      "filament-*": "deny",
      "*domain*": "deny",
      "company-*": "deny"
    }
  },
  "agent": {
    "reviewer": { "model": "openai/gpt-5.5" },
    "security-reviewer": { "model": "openai/gpt-5.5" },
    "architect": { "model": "openai/gpt-5.5" },
    "tester": { "model": "kimi-for-coding/k2p6" },
    "debugger": { "model": "kimi-for-coding/k2p6" },
    "docs-writer": { "model": "kimi-for-coding/k2p5" },
    "pr-writer": { "model": "kimi-for-coding/k2p5" },
    "refactor-planner": { "model": "kimi-for-coding/k2p6" }
  },
  "provider": {
    "openai": {
      "options": {
        "reasoningEffort": "medium",
        "reasoningSummary": "auto",
        "textVerbosity": "medium",
        "include": ["reasoning.encrypted_content"],
        "store": false
      },
      "models": {
        "gpt-5.5": {
          "name": "GPT 5.5 (OAuth)",
          "limit": {
            "context": 1050000,
            "output": 128000
          },
          "modalities": {
            "input": ["text", "image"],
            "output": ["text"]
          },
          "variants": {
            "none": {
              "reasoningEffort": "none",
              "reasoningSummary": "auto",
              "textVerbosity": "medium"
            },
            "low": {
              "reasoningEffort": "low",
              "reasoningSummary": "auto",
              "textVerbosity": "medium"
            },
            "medium": {
              "reasoningEffort": "medium",
              "reasoningSummary": "auto",
              "textVerbosity": "medium"
            },
            "high": {
              "reasoningEffort": "high",
