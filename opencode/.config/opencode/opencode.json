{
  "$schema": "https://opencode.ai/config.json",
  "model": "kimi-for-coding/k2p6",
  "small_model": "openai/gpt-5.4-mini",
  "default_agent": "build",
  "plugin": ["oc-codex-multi-auth"],
  "permission": {
    "skill": {
      "*": "ask",
      "laravel-*": "deny",
      "filament-*": "deny",
      "*domain*": "deny",
      "company-*": "deny"
    }
  },
  "agent": {
    "reviewer": { "model": "openai/gpt-5.5" },
    "security-reviewer": { "model": "openai/gpt-5.5" },
    "architect": { "model": "openai/gpt-5.4-mini" },
    "tester": { "model": "kimi-for-coding/k2p6" },
    "debugger": { "model": "kimi-for-coding/k2p6" },
    "docs-writer": { "model": "openai/gpt-5.4-mini" },
    "pr-writer": { "model": "openai/gpt-5.4-mini" },
    "refactor-planner": { "model": "kimi-for-coding/k2p5" },
    "researcher": {
      "model": "fireworks-ai/accounts/fireworks/models/deepseek-v4-pro"
    },
    "critic": { "model": "fireworks-ai/accounts/fireworks/models/glm-5p1" }
  },
  "provider": {
    "openai": {
      "options": {
        "reasoningEffort": "medium",
        "reasoningSummary": "auto",
        "textVerbosity": "medium",
        "include": ["reasoning.encrypted_content"],
        "store": false
      },
      "models": {
        "gpt-5.5": {
          "name": "GPT 5.5 (OAuth)",
          "limit": { "context": 1050000, "output": 128000 },
          "modalities": { "input": ["text", "image"], "output": ["text"] },
          "variants": {
            "none":   { "reasoningEffort": "none",   "reasoningSummary": "auto",     "textVerbosity": "medium" },
            "low":    { "reasoningEffort": "low",    "reasoningSummary": "auto",     "textVerbosity": "medium" },
            "medium": { "reasoningEffort": "medium", "reasoningSummary": "auto",     "textVerbosity": "medium" },
            "high":   { "reasoningEffort": "high",   "reasoningSummary": "detailed", "textVerbosity": "medium" },
            "xhigh":  { "reasoningEffort": "xhigh",  "reasoningSummary": "detailed", "textVerbosity": "medium" }
          }
        },
        "gpt-5.4": {
          "name": "GPT 5.4 (OAuth)",
          "limit": { "context": 1050000, "output": 128000 },
          "modalities": { "input": ["text", "image"], "output": ["text"] },
          "variants": {
            "none":   { "reasoningEffort": "none",   "reasoningSummary": "auto",     "textVerbosity": "medium" },
            "low":    { "reasoningEffort": "low",    "reasoningSummary": "auto",     "textVerbosity": "medium" },
            "medium": { "reasoningEffort": "medium", "reasoningSummary": "auto",     "textVerbosity": "medium" },
            "high":   { "reasoningEffort": "high",   "reasoningSummary": "detailed", "textVerbosity": "medium" },
            "xhigh":  { "reasoningEffort": "xhigh",  "reasoningSummary": "detailed", "textVerbosity": "medium" }
          }
        },
        "gpt-5.4-mini": {
          "name": "GPT 5.4 Mini (OAuth)",
          "limit": { "context": 400000, "output": 128000 },
          "modalities": { "input": ["text", "image"], "output": ["text"] },
          "variants": {
            "none":   { "reasoningEffort": "none",   "reasoningSummary": "auto",     "textVerbosity": "medium" },
            "low":    { "reasoningEffort": "low",    "reasoningSummary": "auto",     "textVerbosity": "medium" },
            "medium": { "reasoningEffort": "medium", "reasoningSummary": "auto",     "textVerbosity": "medium" },
            "high":   { "reasoningEffort": "high",   "reasoningSummary": "detailed", "textVerbosity": "medium" },
            "xhigh":  { "reasoningEffort": "xhigh",  "reasoningSummary": "detailed", "textVerbosity": "medium" }
          }
        },
        "gpt-5.3-codex": {
          "name": "GPT 5.3 Codex (OAuth)",
          "limit": { "context": 400000, "output": 128000 },
          "modalities": { "input": ["text", "image"], "output": ["text"] },
          "variants": {
            "low":    { "reasoningEffort": "low",    "reasoningSummary": "auto",     "textVerbosity": "medium" },
            "medium": { "reasoningEffort": "medium", "reasoningSummary": "auto",     "textVerbosity": "medium" },
            "high":   { "reasoningEffort": "high",   "reasoningSummary": "detailed", "textVerbosity": "medium" },
            "xhigh":  { "reasoningEffort": "xhigh",  "reasoningSummary": "detailed", "textVerbosity": "medium" }
          },
          "options": {
            "reasoningEffort": "high",
            "reasoningSummary": "detailed",
            "textVerbosity": "medium"
          }
        },
        "gpt-5.2": {
          "name": "GPT 5.2 (OAuth)",
          "limit": { "context": 400000, "output": 128000 },
          "modalities": { "input": ["text", "image"], "output": ["text"] },
          "variants": {
            "none":   { "reasoningEffort": "none",   "reasoningSummary": "auto",     "textVerbosity": "medium" },
            "low":    { "reasoningEffort": "low",    "reasoningSummary": "auto",     "textVerbosity": "medium" },
            "medium": { "reasoningEffort": "medium", "reasoningSummary": "auto",     "textVerbosity": "medium" },
            "high":   { "reasoningEffort": "high",   "reasoningSummary": "detailed", "textVerbosity": "medium" },
            "xhigh":  { "reasoningEffort": "xhigh",  "reasoningSummary": "detailed", "textVerbosity": "medium" }
          }
        }
      }
    }
  }
}
