{
  "$schema": "https://opencode.ai/config.json",
  "model": "kimi-for-coding/k2p6",
  "small_model": "kimi-for-coding/k2p5",
  "default_agent": "build",
  "permission": {
    "edit": "ask",
    "bash": "ask",
    "skill": {
      "*": "ask",
      "laravel-*": "deny",
      "filament-*": "deny",
      "*domain*": "deny",
      "company-*": "deny"
    }
  },
  "agent": {
    "build": {
      "model": "kimi-for-coding/k2p6",
      "permission": {
        "bash": {
          "*": "ask",
          "git status*": "allow",
          "git diff*": "allow",
          "git log*": "allow",
          "npm test*": "allow",
          "pnpm test*": "allow",
          "yarn test*": "allow",
          "go test*": "allow",
          "php artisan test*": "allow",
          "vendor/bin/phpunit*": "allow",
          "pytest*": "allow",
          "git push*": "deny"
        },
        "edit": "ask"
      }
    },
    "plan": {
      "model": "opencode-go/glm-5.1"
    },
    "architect": {
      "model": "opencode-go/glm-5.1"
    },
    "debugger": {
      "model": "kimi-for-coding/k2p6"
    },
    "tester": {
      "model": "kimi-for-coding/k2p6"
    },
    "reviewer": {
      "model": "openai/gpt-5.5"
    },
    "security-reviewer": {
      "model": "openai/gpt-5.5"
    },
    "docs-writer": {
      "model": "openai/gpt-5.4-mini"
    },
    "pr-writer": {
      "model": "openai/gpt-5.4-mini"
    },
    "refactor-planner": {
      "model": "opencode-go/glm-5.1"
    },
    "researcher": {
      "model": "opencode-go/qwen3.7-plus"
    },
    "critic": {
      "model": "opencode-go/qwen3.7-max"
    }
  },
  "provider": {
    "openai": {
      "options": {
        "reasoningEffort": "medium",
        "reasoningSummary": "auto",
        "textVerbosity": "medium",
        "include": [
          "reasoning.encrypted_content"
        ],
        "store": false
      },
      "models": {
        "gpt-5.5": {
          "name": "GPT 5.5 (OAuth)",
          "limit": {
            "context": 1050000,
            "output": 128000
          },
          "modalities": {
            "input": [
              "text",
              "image"
            ],
            "output": [
              "text"
            ]
          },
          "variants": {
            "none": {
              "reasoningEffort": "none",
              "reasoningSummary": "auto",
              "textVerbosity": "medium"
            },
            "low": {
              "reasoningEffort": "low",
              "reasoningSummary": "auto",
              "textVerbosity": "medium"
            },
            "medium": {
