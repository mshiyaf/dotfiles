{
  "$schema": "https://opencode.ai/config.json",
  "model": "kimi-for-coding/k2p6",
  "small_model": "kimi-for-coding/k2p5",
  "default_agent": "build",
  "plugin": ["oc-codex-multi-auth"],
  "permission": {
    "edit": "ask",
    "bash": "ask",
    "skill": {
      "*": "ask",
      "laravel-*": "deny",
      "filament-*": "deny",
      "*domain*": "deny",
      "company-*": "deny"
    }
  },
  "agent": {
    "build": {
      "model": "kimi-for-coding/k2p6",
      "permission": {
        "bash": {
          "*": "ask",
          "git status*": "allow",
          "git diff*": "allow",
          "git log*": "allow",
          "npm test*": "allow",
          "pnpm test*": "allow",
          "yarn test*": "allow",
          "go test*": "allow",
          "php artisan test*": "allow",
          "vendor/bin/phpunit*": "allow",
          "pytest*": "allow",
          "git push*": "deny"
        },
        "edit": "ask"
      }
    },
    "plan": { "model": "fireworks-ai/accounts/fireworks/models/glm-5p1" },
    "architect": { "model": "fireworks-ai/accounts/fireworks/models/glm-5p1" },
    "debugger": { "model": "kimi-for-coding/k2p6" },
    "tester": { "model": "kimi-for-coding/k2p6" },
    "reviewer": { "model": "openai/gpt-5.5" },
    "security-reviewer": { "model": "openai/gpt-5.5" },
    "docs-writer": { "model": "openai/gpt-5.4-mini" },
    "pr-writer": { "model": "openai/gpt-5.4-mini" },
    "refactor-planner": {
      "model": "fireworks-ai/accounts/fireworks/models/glm-5p1"
    },
    "researcher": {
      "model": "fireworks-ai/accounts/fireworks/models/deepseek-v4-pro"
    },
    "critic": { "model": "fireworks-ai/accounts/fireworks/models/glm-5p1" }
  },
  "provider": {
    "openai": {
      "options": {
        "reasoningEffort": "medium",
        "reasoningSummary": "auto",
        "textVerbosity": "medium",
        "include": ["reasoning.encrypted_content"],
        "store": false
      },
      "models": {
        "gpt-5.5": {
          "name": "GPT 5.5 (OAuth)",
          "limit": { "context": 1050000, "output": 128000 },
          "modalities": { "input": ["text", "image"], "output": ["text"] },
          "variants": {
            "none": {
              "reasoningEffort": "none",
              "reasoningSummary": "auto",
              "textVerbosity": "medium"
            },
            "low": {
              "reasoningEffort": "low",
              "reasoningSummary": "auto",
              "textVerbosity": "medium"
            },
            "medium": {
              "reasoningEffort": "medium",
              "reasoningSummary": "auto",
              "textVerbosity": "medium"
            },
            "high": {
              "reasoningEffort": "high",
              "reasoningSummary": "detailed",
              "textVerbosity": "medium"
            },
            "xhigh": {
              "reasoningEffort": "xhigh",
              "reasoningSummary": "detailed",
              "textVerbosity": "medium"
            }
          }
        },
        "gpt-5.4": {
          "name": "GPT 5.4 (OAuth)",
          "limit": { "context": 1050000, "output": 128000 },
          "modalities": { "input": ["text", "image"], "output": ["text"] },
          "variants": {
            "none": {
              "reasoningEffort": "none",
              "reasoningSummary": "auto",
              "textVerbosity": "medium"
