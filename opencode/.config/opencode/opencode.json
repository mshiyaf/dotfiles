{
  "$schema": "https://opencode.ai/config.json",
  "model": "openai/gpt-5.6-terra",
  "small_model": "openai/gpt-5.6-luna-fast",
  "default_agent": "build",
  "enabled_providers": [
    "openai",
    "kimi-for-coding"
  ],
  "permission": {
    "edit": "ask",
    "bash": "ask",
    "skill": {
      "*": "ask",
      "laravel-*": "deny",
      "filament-*": "deny",
      "*domain*": "deny",
      "company-*": "deny"
    }
  },
  "agent": {
    "build": {
      "model": "openai/gpt-5.6-terra-fast",
      "permission": {
        "bash": {
          "*": "ask",
          "git status*": "allow",
          "git diff*": "allow",
          "git log*": "allow",
          "git branch*": "allow",
          "git remote*": "allow",
          "git merge-base*": "allow",
          "git rev-parse*": "allow",
          "npm test*": "allow",
          "pnpm test*": "allow",
          "yarn test*": "allow",
          "go test*": "allow",
          "php artisan test*": "allow",
          "vendor/bin/phpunit*": "allow",
          "pytest*": "allow",
          "git push*": "deny"
        },
        "edit": "ask"
      }
    },
    "plan": {
      "model": "openai/gpt-5.6-sol"
    },
    "architect": {
      "model": "openai/gpt-5.6-sol"
    },
    "debugger": {
      "model": "openai/gpt-5.6-sol"
    },
    "tester": {
      "model": "openai/gpt-5.6-terra"
    },
    "reviewer": {
      "model": "openai/gpt-5.6-terra"
    },
    "security-reviewer": {
      "model": "openai/gpt-5.6-sol-pro"
    },
    "docs-writer": {
      "model": "openai/gpt-5.6-luna-fast"
    },
    "pr-writer": {
      "model": "openai/gpt-5.6-luna-fast"
    },
    "refactor-planner": {
      "model": "openai/gpt-5.6-sol"
    },
    "researcher": {
      "model": "openai/gpt-5.6-sol-fast"
    },
    "critic": {
      "model": "openai/gpt-5.6-sol-pro"
    },
    "captain": {
      "model": "openai/gpt-5.6-terra-fast"
    },
    "crewmate": {
      "model": "openai/gpt-5.6-terra"
    }
  },
  "provider": {
    "openai": {
      "options": {
        "reasoningEffort": "medium",
        "reasoningSummary": "auto",
        "textVerbosity": "medium",
        "include": [
          "reasoning.encrypted_content"
        ],
        "store": false
      },
      "models": {
        "gpt-5.6": {
          "name": "GPT 5.6 (OAuth)",
          "limit": {
            "context": 1050000,
            "output": 128000
