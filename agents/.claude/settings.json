{
  "permissions": {
    "allow": [
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(npm test*)",
      "Bash(pnpm test*)",
      "Bash(yarn test*)",
      "Bash(go test*)",
      "Bash(php artisan test*)",
      "Bash(vendor/bin/phpunit*)",
      "Bash(pytest*)"
    ],
    "deny": [
      "Bash(git push*)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash '/home/mshiyaf/.claude/hooks/herdr-agent-state.sh' session",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "if [ -n \"${TMUX:-}\" ]; then ~/.local/bin/tmux-agents report claude SessionStart; fi",
            "timeout": 10
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "if [ -n \"${TMUX:-}\" ]; then ~/.local/bin/tmux-agents report claude UserPromptSubmit; fi",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "if [ -n \"${TMUX:-}\" ]; then ~/.local/bin/tmux-agents report claude Stop; fi",
            "timeout": 10
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "if [ -n \"${TMUX:-}\" ]; then ~/.local/bin/tmux-agents report claude Notification; fi",
            "timeout": 10
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "if [ -n \"${TMUX:-}\" ]; then ~/.local/bin/tmux-agents report claude SessionEnd; fi",
            "timeout": 10
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.local/bin/claude-statusline"
  },
  "enabledPlugins": {
    "rust-analyzer-lsp@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "37signals": {
      "source": {
        "source": "github",
        "repo": "basecamp/claude-plugins"
      }
    }
  },
  "effortLevel": "high",
  "tui": "fullscreen",
  "agentPushNotifEnabled": true
}
