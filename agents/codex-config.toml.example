# Copy the settings below into ~/.codex/config.toml on each machine.
# Do not symlink this file: Codex appends local project trust and TUI state.

approval_policy = "on-request"
sandbox_mode = "workspace-write"

[tui]
status_line_use_colors = false
status_line = [
  "project-name",
  "git-branch",
  "model-with-reasoning",
  "context-used",
  "used-tokens",
  "five-hour-limit",
  "weekly-limit",
]
